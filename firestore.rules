rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUser(data) {
      return data.keys().hasAll(['callsign', 'trustLevel', 'encryptionStatus', 'activityStatus', 'createdAt', 'updatedAt'])
        && (data.keys().size() == 7 || data.keys().size() == 6)
        && data.callsign is string && data.callsign.size() <= 32
        && data.trustLevel in ['Básico', 'Operacional', 'Veterano', 'Comunidade']
        && (data.region == null || (data.region is string && data.region.size() <= 64))
        && data.encryptionStatus in ['Ativa', 'Inativa']
        && data.activityStatus in ['Online', 'Offline', 'Away']
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().createdAt == existing().createdAt // createdAt is immutable
        && incoming().diff(existing()).affectedKeys().hasOnly(['callsign', 'trustLevel', 'region', 'encryptionStatus', 'activityStatus', 'updatedAt']);
      allow delete: if isOwner(userId);
    }
  }
}
